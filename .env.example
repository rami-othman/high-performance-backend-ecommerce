SECRET_KEY=change-me-in-real-projects
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,web,web2,web3,load_balancer

POSTGRES_DB=ecommerce_db
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=ecommerce_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False

# Task 5 - Load Distribution
# SERVER_NAME identifies the backend instance in /api/server-info/ responses.
SERVER_NAME=web-1
# In Docker, the HAProxy service is reachable as http://load_balancer.
# From the host machine, the same public entrypoint is http://localhost:8000.
LOAD_BALANCER_TEST_REQUESTS=60
LOAD_BALANCER_TEST_BASE_URL=http://load_balancer

# Task 2 checkout capacity limiter.
CHECKOUT_MAX_CONCURRENT_REQUESTS=5
CHECKOUT_CAPACITY_TTL_SECONDS=30
CHECKOUT_CAPACITY_TEST_DELAY_ENABLED=True
ORDER_ASYNC_TASK_TEST_DELAY_ENABLED=True
ORDER_ASYNC_TASK_TEST_DELAY_SECONDS=1.0
DAILY_SALES_BATCH_CHUNK_SIZE=100
DAILY_SALES_BATCH_TEST_ORDER_COUNT=250
DAILY_SALES_BATCH_TEST_CHUNK_SIZE=50

# Docker/Gunicorn web concurrency. Default effective request capacity is
# WEB_CONCURRENCY * GUNICORN_THREADS = 16, which is intentionally higher
# than CHECKOUT_MAX_CONCURRENT_REQUESTS for the Task 2 proof.
WEB_CONCURRENCY=8
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
